{
  "name": "@adamkasper/nuxt-unleash",
  "type": "module",
  "version": "0.0.2-beta.6",
  "packageManager": "pnpm@10.33.0",
  "description": "Nuxt module for Unleash",
  "license": "MIT",
  "repository": "github:adamkasper/nuxt-unleash",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "bumpp",
    "changelog": "changelogen --release",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "docs:dev": "nuxt dev docs --extends docus",
    "docs:build": "nuxt build docs --extends docus",
    "docs:generate": "nuxt generate docs --extends docus",
    "docs:preview": "nuxt preview docs --extends docus",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit",
    "postinstall": "nuxt prepare"
  },
  "peerDependencies": {
    "@nuxthub/core": ">=0.8.0"
  },
  "peerDependenciesMeta": {
    "@nuxthub/core": {
      "optional": true
    }
  },
  "dependencies": {
    "@nuxt/kit": "catalog:",
    "defu": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@nuxt/devtools": "catalog:",
    "@nuxt/eslint-config": "catalog:",
    "@nuxt/module-builder": "catalog:",
    "@nuxt/schema": "catalog:",
    "@nuxt/test-utils": "catalog:",
    "@types/node": "catalog:",
    "bumpp": "catalog:",
    "changelogen": "catalog:",
    "eslint": "catalog:",
    "nuxt": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  }
}
